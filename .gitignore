# Secrets and local env (templates *.env.example are kept on purpose)
**/.env
**/.env.local
**/.env.*.local
**/.env.backup
!**/.env.example
admin/frontend/.env

# Leftover debug / key dumps (never commit)
admin/backend/key.txt
admin/backend/temp_key.txt
admin/backend/test_gemini.php

