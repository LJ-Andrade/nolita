admin/backend/storage/pail
admin/backend/.phpunit.result.cache

# Admin frontend (Vite)
admin/frontend/node_modules/
admin/frontend/dist/
admin/frontend/dist-ssr/
admin/frontend/*.local

# Logs
*.log
admin/backend/storage/logs/*.log
admin/frontend/logs

