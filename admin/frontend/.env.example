# ==============================================================================
# NOLITA VADMIN - ENTORNO DE DESARROLLO (PLANTILLA)
# ==============================================================================
# Instrucciones de uso:
# 1. Copia este archivo y renómbralo como `.env.local` (este archivo será 
#    ignorado por git para no exponer tus credenciales locales).
# 2. Reemplaza los valores con los correspondientes a tu entorno local.

# ------------------------------------------------------------------------------
# API & BACKEND
# ------------------------------------------------------------------------------
# URL base para las peticiones a la API del backend de Laravel.
# Asegúrate de terminar la URL con un slash (/) final si tu código lo requiere.
VITE_API_URL=http://nolita.test/api
# ------------------------------------------------------------------------------
# CONFIGURACIONES DE LA APLICACIÓN
# ------------------------------------------------------------------------------
# Nombre de la aplicación (usado en el `<title>` y en la interfaz)
VITE_APP_NAME="Nolita Admin"

# Define el entorno de ejecución (development, staging, production)
VITE_APP_ENV=development

# (Opcional) Limite de resultados por página en los listados
# VITE_DEFAULT_PAGE_SIZE=15

# (Opcional) Activar / Desactivar logs adicionales en consola para depuración
# VITE_ENABLE_DEBUG_LOGS=true
